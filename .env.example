# ────────────────────────────────────────────────────────────────────────────
# .env.example — plantilla completa de variables de entorno
#
# Copiar al archivo del ambiente correspondiente y rellenar los valores:
#   cp .env.example .env.dev      # desarrollo local
#   cp .env.example .env.staging  # staging
#   cp .env.example .env.prod     # producción
#
# Seleccionar ambiente al ejecutar:
#   APP_ENV=development uvicorn app.main:app --reload   (por defecto)
#   APP_ENV=staging     uvicorn app.main:app
#   APP_ENV=production  uvicorn app.main:app
# ────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=MedSync
ENVIRONMENT=development            # development | staging | production
DEBUG=False

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/medsync_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption ────────────────────────────────────────────────────────────────
# Comma-separated base64-encoded 32-byte keys, ordered oldest→newest.
# Generar con: python -c "from app.core.crypto import generate_key_b64; print(generate_key_b64())"
ENCRYPTION_KEYS=CHANGE_ME_base64_32bytes
# Generar con: openssl rand -hex 32
SEARCH_HMAC_KEY=CHANGE_ME_openssl_rand_hex_32

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Dev: usar Mailpit (docker run -p 1025:1025 -p 8025:8025 axllent/mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@medsync.com
SMTP_TLS=False

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000

# ── Redis (rate limiting) ──────────────────────────────────────────────────────
# Vacío = contador en memoria (solo funciona con un worker).
# Con múltiples workers (Gunicorn/--workers N), configurar Redis para que los
# contadores sean compartidos y los límites se apliquen correctamente.
#
# Desarrollo:  docker compose up -d  →  redis://localhost:6379
# Producción:  Upstash, Redis Cloud, Elasticache…
#
# rediss:// activa TLS (requerido por Upstash y Redis Cloud en producción).
REDIS_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma (sin espacios entre comas).
# Dev: http://localhost:3000   Prod: https://medsync.clinic
CORS_ORIGINS=http://localhost:3000,https://medsync.clinic

# ── AWS (dejar vacíos para deshabilitar) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_RECORDS=medical-records-dev
S3_PRESIGNED_URL_TTL=300

# ── Stripe (dejar vacíos para deshabilitar billing) ───────────────────────────
# Dev: usar keys sk_test_... y whsec_... del modo Test en el Dashboard.
# Webhook local: instalar stripe CLI → stripe listen --forward-to localhost:8000/api/v1/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# ── Reglas de negocio ─────────────────────────────────────────────────────────
# Horas mínimas de anticipación que necesita el paciente para cancelar su cita.
PATIENT_CANCEL_HOURS_BEFORE=1
