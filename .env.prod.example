# ────────────────────────────────────────────────────────────────────────────────
# .env.prod.example  —  plantilla para producción
#
# PASOS PARA CREAR TU .env.prod REAL:
#
#   1. Genera los secretos criptográficos:
#        python scripts/generate_secrets.py --write
#      Esto crea .env.prod con JWT_SECRET_KEY, SEARCH_HMAC_KEY y ENCRYPTION_KEYS
#      ya generados. El archivo tendrá permisos 600.
#
#   2. Edita .env.prod y reemplaza cada valor marcado con COMPLETAR.
#
#   3. Verifica antes de arrancar:
#        APP_ENV=production python -c "from app.core.config import settings; print('OK')"
#      Si hay algún placeholder sin reemplazar, el validador lo detecta y falla.
#
#   NUNCA commitas .env.prod al repositorio (.gitignore ya lo excluye).
#   Guarda una copia en tu gestor de secretos (Vault, AWS SSM, 1Password Teams).
# ────────────────────────────────────────────────────────────────────────────────


# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=MedSync
ENVIRONMENT=production
DEBUG=False


# ── Base de datos ─────────────────────────────────────────────────────────────
#
# Formato:
#   postgresql+asyncpg://<usuario>:<contraseña>@<host>:<puerto>/<nombre_db>
#
# Opciones comunes en producción:
#   Supabase:    Session Pooler (puerto 5432) + ?prepared_statement_cache_size=0
#   Neon:        Pooled connection string, agrega +asyncpg y ?sslmode=require
#   AWS RDS:     endpoint del cluster, habilita SSL en el security group
#   Bare metal:  host del servidor, usuario dedicado con permisos mínimos
#
DATABASE_URL=postgresql+asyncpg://medsync:COMPLETAR@COMPLETAR:5432/medsync_prod
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10


# ── JWT ───────────────────────────────────────────────────────────────────────
# Generado automáticamente por: python scripts/generate_secrets.py --write
# Para regenerar manualmente:   openssl rand -hex 32
JWT_SECRET_KEY=COMPLETAR
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Cifrado de campos PII (NOM-024 / HIPAA) ───────────────────────────────────
# Generado automáticamente por: python scripts/generate_secrets.py --write
#
# ENCRYPTION_KEYS: coma-separado, base64 de 32 bytes, ordenado viejo→nuevo.
#   El ÚLTIMO elemento es la clave activa para nuevos registros.
#   Rotación sin downtime: python scripts/generate_secrets.py --rotate
#
# SEARCH_HMAC_KEY: hex de 32 bytes. Distinto de cualquier clave de cifrado.
#   ⚠  Si cambias este valor se invalidan TODOS los search_hash existentes
#      y el login deja de funcionar. Nunca rotar sin un job de rehash.
#
ENCRYPTION_KEYS=COMPLETAR
SEARCH_HMAC_KEY=COMPLETAR


# ── URLs ──────────────────────────────────────────────────────────────────────
# APP_BASE_URL: usado en los enlaces de correo (confirmación de cita, reset de contraseña).
#   Debe ser el dominio público del backend (o del frontend si el frontend
#   intercepta los magic links).
APP_BASE_URL=https://COMPLETAR.com


# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista separada por coma, sin espacios. Solo dominios que sirven el frontend.
# Nunca incluir "null" ni "http://" en producción.
CORS_ORIGINS=https://COMPLETAR.com


# ── SMTP (Resend — recomendado) ───────────────────────────────────────────────
#
# Resend (resend.com):
#   1. Crear cuenta y verificar dominio en Settings → Domains
#   2. Crear API key en Settings → API Keys (permisos: Sending access)
#   3. SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USER=resend
#   4. SMTP_PASSWORD=re_xxxxxxxxxxxx  (tu API key)
#
# SendGrid (alternativa):
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
#   SMTP_PASSWORD=SG.xxxxxxxxxxxx
#
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=COMPLETAR
SMTP_TLS=True
EMAILS_FROM=noreply@COMPLETAR.com

# Bandeja que recibe las notificaciones de solicitud de reagendado de pacientes.
CLINIC_NOTIFY_EMAIL=COMPLETAR@COMPLETAR.com


# ── Redis (rate limiting multi-worker) ───────────────────────────────────────
#
# OBLIGATORIO con múltiples workers (Gunicorn --workers N / uvicorn --workers N).
# Sin Redis, cada worker lleva su propio contador y el límite real es
#   workers × límite_config  (p.ej. 4 workers × 5/min login = 20 req/min reales).
#
# Proveedores recomendados:
#   Upstash      →  rediss://default:<token>@<host>.upstash.io:6379
#   Redis Cloud  →  rediss://default:<pass>@<host>.cloud.redislabs.com:6379
#   AWS ElastiCache (VPC) →  redis://<host>:6379
#   Render / Railway      →  redis://<internal-host>:6379
#
# En todos los casos de producción usar rediss:// (TLS) salvo redes privadas.
REDIS_URL=rediss://default:COMPLETAR@COMPLETAR.upstash.io:6379

# ── Reglas de negocio ─────────────────────────────────────────────────────────
# Horas mínimas de anticipación para que un paciente cancele su cita.
PATIENT_CANCEL_HOURS_BEFORE=2


# ── AWS S3 — OBLIGATORIO en producción ───────────────────────────────────────
#
# Los PDFs de expedientes médicos se almacenan en S3.
# Sin credenciales válidas, los endpoints de subida de PDF responden HTTP 503.
#
# PASOS para configurar:
#   1. Crear un bucket PRIVADO (Block all public access = ON).
#   2. Habilitar SSE-S3 (AES-256) como cifrado por defecto del bucket.
#   3. Crear usuario IAM con política mínima:
#        s3:PutObject   → arn:aws:s3:::BUCKET_NAME/medical-records/*
#        s3:GetObject   → arn:aws:s3:::BUCKET_NAME/medical-records/*
#        s3:DeleteObject→ arn:aws:s3:::BUCKET_NAME/medical-records/*
#   4. Generar Access Key para ese usuario y pegar aquí.
#
# Alternativa sin AWS: Cloudflare R2 (compatible con API S3, sin costo de egress)
#   AWS_REGION=auto
#   Use el endpoint de R2 como endpoint_url en boto3 (ajustar app/core/s3.py).
#
AWS_ACCESS_KEY_ID=COMPLETAR
AWS_SECRET_ACCESS_KEY=COMPLETAR
AWS_REGION=us-east-1
S3_BUCKET_RECORDS=medsync-records-prod
S3_PRESIGNED_URL_TTL=300
#
# Después del primer deploy, migrar archivos locales existentes a S3:
#   APP_ENV=production python scripts/migrate_pdfs_to_s3.py --dry-run
#   APP_ENV=production python scripts/migrate_pdfs_to_s3.py --delete-local


# ── Stripe ────────────────────────────────────────────────────────────────────
#
# 1. Stripe secret key: Dashboard → Developers → API keys → Secret key
#    En prod usa la clave live (sk_live_...), no la test.
# 2. Webhook secret: Dashboard → Webhooks → tu endpoint → Signing secret
#    Registrar el endpoint: https://TUDOMINIO.com/api/v1/webhooks/stripe
#    Eventos a escuchar:
#      checkout.session.completed
#      customer.subscription.updated
#      customer.subscription.deleted
# 3. Price IDs: Dashboard → Products → (tu producto) → Precios
#    Crear un precio por combinación de plan × período de facturación.
#
STRIPE_SECRET_KEY=sk_live_COMPLETAR
STRIPE_WEBHOOK_SECRET=whsec_COMPLETAR

STRIPE_PRICE_STARTER_MONTHLY=price_COMPLETAR
STRIPE_PRICE_STARTER_ANNUAL=price_COMPLETAR
STRIPE_PRICE_GROWTH_MONTHLY=price_COMPLETAR
STRIPE_PRICE_GROWTH_ANNUAL=price_COMPLETAR
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_COMPLETAR
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_COMPLETAR
